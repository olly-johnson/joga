generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  PLAYER
  CAPTAIN
  REFEREE
  VENUE_ADMIN
  SUPER_ADMIN
}

enum PitchType {
  FIVE_A_SIDE
  SEVEN_A_SIDE
}

enum MatchType {
  FRIENDLY
  RANKED
}

enum MatchStatus {
  OPEN
  BOOKED
  COMPLETED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  MOCKED_PAID
}

enum Team {
  HOME
  AWAY
}

model User {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  clerkId   String   @unique @map("clerk_id")
  email     String   @unique
  firstName String   @map("first_name")
  lastName  String   @map("last_name")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  roles              UserRole[]
  bookings           Booking[]
  refereedMatches    Match[]
  matchParticipants  MatchParticipant[]
  eloRatings         EloRating[]

  @@map("users")
}

model UserRole {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      Role
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@map("user_roles")
}

model Venue {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String
  latitude        Float
  longitude       Float
  stripeAccountId String?  @map("stripe_account_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  pitches Pitch[]

  @@map("venues")
}

model Pitch {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  venueId   String    @map("venue_id") @db.Uuid
  type      PitchType
  surface   String
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  venue   Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)
  matches Match[]

  @@index([venueId])
  @@map("pitches")
}

model Match {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pitchId   String      @map("pitch_id") @db.Uuid
  matchType MatchType   @map("match_type")
  startTime DateTime    @map("start_time")
  endTime   DateTime    @map("end_time")
  status    MatchStatus @default(OPEN)
  refereeId String?     @map("referee_id") @db.Uuid
  homeScore Int?        @map("home_score")
  awayScore Int?        @map("away_score")
  createdAt DateTime    @default(now()) @map("created_at")
  updatedAt DateTime    @updatedAt @map("updated_at")

  pitch        Pitch              @relation(fields: [pitchId], references: [id], onDelete: Cascade)
  referee      User?              @relation(fields: [refereeId], references: [id], onDelete: SetNull)
  booking      Booking?
  participants MatchParticipant[]
  eloRatings   EloRating[]

  @@index([pitchId, startTime, endTime])
  @@map("matches")
}

model Booking {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId       String        @unique @map("match_id") @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  paymentStatus PaymentStatus @default(PENDING) @map("payment_status")
  totalCost     Int           @map("total_cost")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bookings")
}

model MatchParticipant {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  matchId   String   @map("match_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  team      Team
  createdAt DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([matchId])
  @@map("match_participants")
}

model EloRating {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String   @map("user_id") @db.Uuid
  matchId      String   @map("match_id") @db.Uuid
  ratingBefore Int      @map("rating_before")
  ratingAfter  Int      @map("rating_after")
  createdAt    DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)

  @@unique([matchId, userId])
  @@index([userId, createdAt])
  @@map("elo_ratings")
}
