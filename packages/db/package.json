{
  "name": "@footballtomic/db",
  "version": "0.0.1",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "dotenv -e ../../.env --no-expand -- jest",
    "test:watch": "dotenv -e ../../.env --no-expand -- jest --watch",
    "db:migrate": "dotenv -e ../../.env --no-expand -- prisma migrate dev",
    "db:seed": "dotenv -e ../../.env --no-expand -- prisma db seed",
    "db:studio": "dotenv -e ../../.env --no-expand -- prisma studio",
    "db:generate": "dotenv -e ../../.env --no-expand -- prisma generate",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.ts\""
  },
  "dependencies": {
    "@footballtomic/elo": "workspace:*",
    "@prisma/client": "^6.6.0",
    "bullmq": "^5.74.1",
    "ioredis": "^5.10.1"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "dotenv": "^16.4.0",
    "jest": "^29.7.0",
    "prisma": "^6.6.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  }
}
